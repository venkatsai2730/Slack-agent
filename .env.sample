# Slack tokens (from api.slack.com/apps after creating the app from manifest.json)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# LLM — any OpenAI-compatible endpoint. Defaults target the free Hugging Face Inference router.
# Get a free token at https://huggingface.co/settings/tokens (read access is enough).
LLM_BASE_URL=https://router.huggingface.co/v1
LLM_API_KEY=hf_your-huggingface-token-here
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Alternative (local, fully free, no key): uncomment for Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# Channel for /cb-impact reports and high-priority need escalations.
# Leave unset to post in the channel where the command is run / need was detected.
# COMMUNITY_ALERTS_CHANNEL=#community-needs

# Minimum confidence (0.0-1.0) a detected signal needs before it triggers a live Slack alert card.
SIGNAL_CONFIDENCE_THRESHOLD=0.6

# Case-log (CRM) provider: mock | hubspot | salesforce (mock is fully functional out of the box)
CRM_PROVIDER=mock

# HubSpot (only needed when CRM_PROVIDER=hubspot — provider is currently a stub, see services/crm/hubspotProvider.js)
# HUBSPOT_API_KEY=

# Salesforce Nonprofit Cloud (only needed when CRM_PROVIDER=salesforce — provider is currently a stub, see services/crm/salesforceProvider.js)
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_INSTANCE_URL=

# --- Proactive escalation (Feature 2) ---------------------------------------

# Comma-separated Slack user IDs to DM when a signal is escalated. Leave unset
# to skip DMs and only post to COMMUNITY_ALERTS_CHANNEL.
# COORDINATOR_USER_IDS=U012ABCDEF,U034GHIJKL

ESCALATION_ENABLED=true
ESCALATION_CHECK_MINUTES=60
ESCALATION_AGE_HOURS_CRITICAL=1
ESCALATION_AGE_HOURS_HIGH=4
ESCALATION_AGE_HOURS_ROUTINE=24
ESCALATION_MAX_REMINDERS=3
# Quiet hours as local server hours (0-23); escalations are suppressed in this window.
ESCALATION_QUIET_HOURS_START=22
ESCALATION_QUIET_HOURS_END=7

# LOW-confidence match outreach target (Feature 3). Falls back to
# COMMUNITY_ALERTS_CHANNEL, then the source channel, if unset.
# VOLUNTEERS_NEEDED_CHANNEL=#volunteers-needed

# Per-channel cap on LLM-triggering signal detections per minute (abuse/cost control).
RATE_LIMIT_LLM_PER_CHANNEL_PER_MIN=20
