# Slack tokens (from api.slack.com/apps after creating the app from manifest.json)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# LLM — any OpenAI-compatible endpoint. Defaults target the free Hugging Face Inference router.
# Get a free token at https://huggingface.co/settings/tokens (read access is enough).
LLM_BASE_URL=https://router.huggingface.co/v1
LLM_API_KEY=hf_your-huggingface-token-here
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Alternative (local, fully free, no key): uncomment for Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# Channel for /gb-report and high-priority signal escalations.
# Leave unset to post in the channel where the command is run / signal was detected.
# GROWTH_ALERTS_CHANNEL=#growth-signals

# Minimum confidence (0.0-1.0) a detected signal needs before it triggers a live Slack alert card.
SIGNAL_CONFIDENCE_THRESHOLD=0.6

# CRM provider: mock | hubspot | salesforce (mock is fully functional out of the box)
CRM_PROVIDER=mock

# HubSpot (only needed when CRM_PROVIDER=hubspot — provider is currently a stub, see services/crm/hubspotProvider.js)
# HUBSPOT_API_KEY=

# Salesforce (only needed when CRM_PROVIDER=salesforce — provider is currently a stub, see services/crm/salesforceProvider.js)
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_INSTANCE_URL=
